APP_NAME=FinancialAuditAI
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173

POSTGRES_DB=financial_audit_ai
POSTGRES_USER=financial_audit_ai
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://financial_audit_ai:change-me-local-only@localhost:5432/financial_audit_ai

EMBEDDING_PROVIDER=deterministic-local
EMBEDDING_DIMENSIONS=32
OCR_PROVIDER=pymupdf-local
OCR_API_URL=
OCR_API_KEY=
OCR_MODEL=financialauditai-ocr
OCR_TIMEOUT_SECONDS=30
LLM_PROVIDER=deterministic-fallback
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=financialauditai-local
LLM_TIMEOUT_SECONDS=20
RAG_RERANK_PROVIDER=deterministic-fallback
RAG_ANSWER_PROVIDER=deterministic-fallback

AUTH_SECRET_KEY=change-me-local-auth-secret
ACCESS_TOKEN_MINUTES=480

VITE_API_BASE_URL=http://localhost:8000
